<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark first. The camera screen has no action bar and a black backdrop. -->
    <style name="Theme.ElendheimCapture" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Settings screen: dark with an action bar and the preference styling. -->
    <style name="Theme.ElendheimCapture.Settings" parent="Theme.Material3.Dark">
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

</resources>
