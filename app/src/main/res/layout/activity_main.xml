<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Placement (box vs full screen) is set in code per photo or video. -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:implementationMode="compatible"
        app:layout_constraintVertical_bias="0.22"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Rule of thirds grid, lined up with the camera image. -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/grid"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- Corner glow used as a flash for the selfie camera. -->
    <com.truecapture.app.VignetteView
        android:id="@+id/vignetteOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/recordIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_zoom_bar"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/zoomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dot_red" />

        <Chronometer
            android:id="@+id/recordTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Filter picker, shown when the filter button is tapped. -->
    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_zoom_bar"
        android:paddingVertical="4dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/zoomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/filterBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp" />

    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_zoom_bar"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/modeRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/modeRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/shutterButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/modePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/mode_photo"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/modeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/mode_video"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/shutterButton"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_shutter_photo"
        android:contentDescription="@string/take_photo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/flashButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp"
        android:background="@drawable/bg_round_button"
        android:src="@drawable/ic_flash_off"
        android:scaleType="fitCenter"
        android:contentDescription="@string/flash_off"
        app:layout_constraintTop_toTopOf="@id/shutterButton"
        app:layout_constraintBottom_toBottomOf="@id/shutterButton"
        app:layout_constraintEnd_toStartOf="@id/shutterButton" />

    <!-- Filters, on the left. -->
    <ImageButton
        android:id="@+id/filterButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="10dp"
        android:padding="11dp"
        android:background="@drawable/bg_round_button"
        android:src="@drawable/ic_filter"
        android:scaleType="fitCenter"
        android:contentDescription="@string/filters"
        app:layout_constraintTop_toTopOf="@id/shutterButton"
        app:layout_constraintBottom_toBottomOf="@id/shutterButton"
        app:layout_constraintEnd_toStartOf="@id/flashButton" />

    <ImageButton
        android:id="@+id/flipButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:padding="12dp"
        android:background="@drawable/bg_round_button"
        android:src="@drawable/ic_flip"
        android:scaleType="fitCenter"
        android:contentDescription="@string/flip_camera"
        app:layout_constraintTop_toTopOf="@id/shutterButton"
        app:layout_constraintBottom_toBottomOf="@id/shutterButton"
        app:layout_constraintStart_toEndOf="@id/shutterButton" />

    <!-- Settings, on the right, low down and out of the way. -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:padding="10dp"
        android:background="@drawable/bg_round_button"
        android:src="@drawable/ic_settings"
        android:scaleType="fitCenter"
        android:contentDescription="@string/settings"
        app:layout_constraintTop_toTopOf="@id/shutterButton"
        app:layout_constraintBottom_toBottomOf="@id/shutterButton"
        app:layout_constraintStart_toEndOf="@id/flipButton" />

    <!-- Full screen catcher. While the editor is open this sits behind it and
         eats any taps, so nothing behind the panel can be pressed. -->
    <View
        android:id="@+id/editorScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Custom filter editor. Sliders update the preview live. -->
    <ScrollView
        android:id="@+id/filterEditor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#F0121212"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/filterName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Filter name"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:autofillHints="name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Warmth"
                android:textColor="#FFFFFF" />

            <SeekBar
                android:id="@+id/warmthSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:contentDescription="Warmth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tint"
                android:textColor="#FFFFFF" />

            <SeekBar
                android:id="@+id/tintSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:contentDescription="Tint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brightness"
                android:textColor="#FFFFFF" />

            <SeekBar
                android:id="@+id/brightnessSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:contentDescription="Brightness" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contrast"
                android:textColor="#FFFFFF" />

            <SeekBar
                android:id="@+id/contrastSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:contentDescription="Contrast" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saturation"
                android:textColor="#FFFFFF" />

            <SeekBar
                android:id="@+id/saturationSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="100"
                android:contentDescription="Saturation" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/deleteFilter"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delete"
                    android:textColor="#FF5252" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/cancelFilter"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel" />

                <Button
                    android:id="@+id/saveFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Black overlay flashed briefly when a photo is taken (shutter effect). -->
    <View
        android:id="@+id/shutterOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
